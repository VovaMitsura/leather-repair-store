# Copy this file to .env.local for development (Vite auto-loads .env.local).
# In production (Vercel), set these in the project's Environment Variables UI.

# --- Email (Resend) ---
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The address that receives contact form submissions.
TO_EMAIL=owner@example.com
# The "From" address. Must be a verified domain in Resend, or use
# "Leather Repair <onboarding@resend.dev>" for sandbox testing only.
FROM_EMAIL=Leather Repair <hello@yourdomain.com>

# --- CORS ---
# Comma-separated list of origins permitted to call /api/contact.
# Example for production: https://mitsuraleatherrepair.com,https://www.mitsuraleatherrepair.com
# Leave unset locally — the Express dev server falls back to localhost ports.
ALLOWED_ORIGINS=

# --- Server ---
# Local Express port (defaults to 3001).
PORT=3001
